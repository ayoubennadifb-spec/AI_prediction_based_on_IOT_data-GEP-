# InfluxDB connection (SERVER-SIDE ONLY — never exposed to the browser).
# Read only inside Next.js API routes (app/api/series/route.ts).
#
# "2 bases" architecture:
#   SOURCE = Ayman's InfluxDB  -> the dashboard READS the live MEASURED data
#   DEST   = YOUR InfluxDB      -> the dashboard READS the PREDICTIONS (worker writes them)

# ============ SOURCE = Ayman's InfluxDB (measured/live) ============
SRC_INFLUX_URL=https://us-east-1-1.aws.cloud2.influxdata.com
SRC_INFLUX_ORG=                  # Ayman's org
# One token per bucket (the existing ESP32 tokens), OR a single all-access one below:
SRC_INFLUX_TOKEN_ZONE1=          # token for bucket Data  (from a (1).py)
SRC_INFLUX_TOKEN_ZONE2=          # token for bucket Zone2 (from a2 (1).py)
SRC_INFLUX_TOKEN=                # optional fallback: single all-access read token
SRC_BUCKET_ZONE1=Data
SRC_BUCKET_ZONE2=Zone2

# ============ DESTINATION = YOUR InfluxDB (predictions) ============
DST_INFLUX_URL=                  # your InfluxDB url
DST_INFLUX_ORG=                  # your org
DST_INFLUX_TOKEN=                # your READ token (read on the predictions bucket is enough for the dashboard)
DST_BUCKET=predictions
