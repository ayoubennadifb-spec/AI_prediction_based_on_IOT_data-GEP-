# Copy to ".env" for local runs (python-dotenv loads it automatically).
# On Render, set these in the dashboard / an env group -- NEVER commit real tokens.
#
# "2 bases" architecture:
#   SOURCE = Ayman's InfluxDB  -> you READ the live sensors
#   DEST   = YOUR InfluxDB      -> the worker WRITES the predictions
# You only fill the two tokens + the two url/org. The rest has defaults.

# ============ SOURCE = Ayman's InfluxDB (READ the live sensors) ============
SRC_INFLUX_URL=https://us-east-1-1.aws.cloud2.influxdata.com
SRC_INFLUX_ORG=                      # <<< Ayman's org, e.g. e873aeb2e2a1406c
# Ayman has ONE token per bucket (the existing ESP32 tokens in a(1)/a2(1)):
SRC_INFLUX_TOKEN_ZONE1=              # <<< token for bucket Data  (from a (1).py)
SRC_INFLUX_TOKEN_ZONE2=              # <<< token for bucket Zone2 (from a2 (1).py)
# OR, if you have ONE all-access read token, set this instead and leave the two above empty:
SRC_INFLUX_TOKEN=
SRC_BUCKET_ZONE1=Data
SRC_BUCKET_ZONE2=Zone2

# ============ DESTINATION = YOUR InfluxDB (WRITE the predictions) ==========
DST_INFLUX_URL=                      # <<< your InfluxDB url (e.g. https://<region>.aws.cloud2.influxdata.com)
DST_INFLUX_ORG=                      # <<< your org (name or id)
DST_INFLUX_TOKEN=                    # <<< your Read+Write token (on the predictions bucket)
DST_BUCKET=predictions

# ============ Worker (optional; defaults shown) ===========================
PREDICT_EVERY_SEC=600                # forecast cadence (10 min)
SERVE_ZONE2_PROXY=true               # serve Zone 2 with the co2-mean proxy
